# ============================================================
# API Pool Test Platform - 环境变量示例
# ------------------------------------------------------------
# 使用方法:
#   1. cp .env.example .env
#   2. 把占位符替换成真实值
#   3. .env 已被 .gitignore,不要提交
# ------------------------------------------------------------
# 安全提醒:
#   * 真实 API Key 只能写在本机的 .env
#   * 前端不持有任何密钥,所有上游调用一律走后端
# ============================================================

# M2 起真实上游不再使用单一 AI_BASE_URL / AI_API_KEY,而是读取 data/channels.json。
# 下面两个字段仅保留兼容旧 .env;新配置请看 README/CLAUDE 里的 channels.json 示例。
# 本地代理示例: http://127.0.0.1:8990/v1
# 官方示例:    https://api.openai.com/v1
AI_BASE_URL=https://your-ai-endpoint.example.com/v1

# 旧单上游访问密钥占位。M2 新号池 key 写入 data/channels.json,不要提交。
AI_API_KEY=YOUR_API_KEY_HERE

# 默认模型名。channel.models 为空时才回落到这个值。
AI_MODEL=gpt-4o-mini

# AI 实现:true=fake(默认,本地模拟),false=通过 data/channels.json 里的 channel 调真模型
USE_FAKE_AI=true

# 系统提示词。空串则不发送 system 消息。
AI_SYSTEM_PROMPT=

# 调试 / 环境
DEBUG=true
ENV=dev
LOG_LEVEL=INFO

# 单会话保留的最大消息条数,内存版用它防止历史无限增长
SESSION_MAX_MESSAGES=100

# M2 总会话内存保护:清空闲置/过量会话的消息体,但保留 session 元信息
MAX_ACTIVE_SESSIONS=1000
SESSION_IDLE_TTL_MINUTES=60

# M2 failover 黑名单窗口。5xx / 429 / 超时 / 连接错误会临时拉黑 channel。
CHANNEL_BLACKLIST_SECONDS=30

# 上游请求超时(秒)
REQUEST_TIMEOUT=30

# ============================================================
# JWT 鉴权
# ============================================================
# JWT_SECRET 泄漏 = 任何人都能伪造 token,绝不能提交进 git。
# 生成: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=请替换成上面命令生成的随机串
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS 允许的来源。必须是 JSON 数组写法。
# API Key 加密密钥 (Fernet)。用于可逆加密存储用户的原始 API Key，支持按需查看。
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=请替换成上面命令生成的随机串
